# Backend environment variables (copy to .env and fill values)
# Database connection string (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ptmp?schema=public"

# Server
PORT=4000
NODE_ENV=development
API_PREFIX=/api

# JWT
JWT_SECRET="change-me-to-a-long-random-secret-string"
JWT_EXPIRES_IN=7d

# CORS (comma-separated allowed origins for the frontend)
CORS_ORIGIN="http://localhost:3000"
